{# Weekly digest template — markdown format, suitable for DingTalk or other
   markdown channels. Shows top entries from the past 7 days grouped by grade. #}
# 📰 InfoDigest 周报

> {{ generated_at }} · 本周 {{ entries|length }} 条精选 · 来源 {{ sources|length }}

{% set ns = namespace(seen_a=false, seen_b=false) %}
{% set grade_emoji = {"A": "🔥", "B": "📌", "C": "📄"} %}
{% for entry in entries %}
{% if entry.grade == "A" and not ns.seen_a %}
## 🔥 本周 A 级推荐（必读）
{% set ns.seen_a = true %}
{% elif entry.grade == "B" and not ns.seen_b %}
## 📌 本周 B 级关注
{% set ns.seen_b = true %}
{% endif %}
{{ grade_emoji.get(entry.grade, "•") }} [{{ entry.title }}]({{ entry.link }})
{% if entry.summary %}{{ entry.summary[:200] }}{% if entry.summary|length > 200 %}...{% endif %}{% endif %}

{% endfor %}

{# Feishu interactive card JSON template. A-grade entries highlighted.
   Uses loop.last to avoid trailing commas. #}
{
  "msg_type": "interactive",
  "card": {
    "config": { "wide_screen_mode": true },
    "header": {
      "title": { "tag": "plain_text", "content": "📰 InfoDigest 每日推送" },
      "template": "blue"
    },
    "elements": [
      {
        "tag": "div",
        "text": { "tag": "lark_md", "content": "**{{ generated_at }}** · 共 {{ entries|length }} 条 · 来源 {{ sources|length }}" }
      },
      { "tag": "hr" },
      {% for entry in entries %}
      {% if entry.grade == "A" %}
      {
        "tag": "note",
        "elements": [
          { "tag": "lark_md", "content": "🔥 **[A 推荐]** [{{ entry.title }}]({{ entry.link }})\n{{ entry.summary[:120] }}{% if entry.summary|length > 120 %}...{% endif %}" }
        ]
      }{% if not loop.last %},{% endif %}
      {% else %}
      {
        "tag": "div",
        "text": {
          "tag": "lark_md",
          "content": "{{ grade_label(entry.grade) }} [{{ entry.title }}]({{ entry.link }})\n{{ entry.summary[:120] }}{% if entry.summary|length > 120 %}...{% endif %}"
        }
      }{% if not loop.last %},{% endif %}
      {% endif %}
      {% endfor %},
      {
        "tag": "note",
        "elements": [
          { "tag": "plain_text", "content": "InfoDigest · 开源自驱信息收集系统" }
        ]
      }
    ]
  }
}
